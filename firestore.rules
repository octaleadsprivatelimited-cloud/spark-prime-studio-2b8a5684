rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to submit the contact form (anonymous submissions)
    match /contact_submissions/{document} {
      // Authenticated admins can read inquiries inside the admin panel
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email', 'message'])
                    && request.resource.data.name is string
                    && request.resource.data.phone is string
                    && request.resource.data.email is string
                    && request.resource.data.message is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.phone.size() <= 15
                    && request.resource.data.email.size() <= 255
                    && request.resource.data.message.size() <= 1000;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    // Public site content — anyone can read, only authenticated admins can write
    match /site_projects/{document}      { allow read: if true; allow write: if request.auth != null; }
    match /site_services/{document}      { allow read: if true; allow write: if request.auth != null; }
    match /site_clients/{document}       { allow read: if true; allow write: if request.auth != null; }
    match /site_testimonials/{document}  { allow read: if true; allow write: if request.auth != null; }
    match /site_hero_slides/{document}   { allow read: if true; allow write: if request.auth != null; }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
